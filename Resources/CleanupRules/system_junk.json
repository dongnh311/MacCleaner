{
  "version": 1,
  "rules": [
    {
      "id": "user_caches_root",
      "name": "User application caches",
      "description": "Per-app caches that macOS regenerates on demand.",
      "paths": ["~/Library/Caches"],
      "exclusions": [
        "~/Library/Caches/com.apple.CloudKit",
        "~/Library/Caches/CloudKit"
      ],
      "category": "user_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "user_logs",
      "name": "User logs",
      "description": "Old log files from user-space apps.",
      "paths": ["~/Library/Logs"],
      "exclusions": null,
      "category": "user_log",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "diagnostic_reports",
      "name": "Crash reports",
      "description": "Old DiagnosticReports files.",
      "paths": ["~/Library/Logs/DiagnosticReports"],
      "exclusions": null,
      "category": "user_log",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "saved_application_state",
      "name": "Saved application state",
      "description": "Per-app window state snapshots — recreated on next launch.",
      "paths": ["~/Library/Saved Application State"],
      "exclusions": null,
      "category": "user_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "xcode_derived_data",
      "name": "Xcode DerivedData",
      "description": "Xcode build intermediates. Re-generated on next build.",
      "paths": ["~/Library/Developer/Xcode/DerivedData"],
      "exclusions": null,
      "category": "xcode_junk",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "ios_simulator_caches",
      "name": "iOS Simulator caches",
      "description": "Cached simulator runtimes and downloads.",
      "paths": ["~/Library/Developer/CoreSimulator/Caches"],
      "exclusions": null,
      "category": "xcode_junk",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "ios_device_support",
      "name": "iOS device support symbols",
      "description": "Symbolicated images for iOS versions you may no longer test.",
      "paths": ["~/Library/Developer/Xcode/iOS DeviceSupport"],
      "exclusions": null,
      "category": "xcode_junk",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "watchos_device_support",
      "name": "watchOS device support symbols",
      "description": "Symbolicated images for watchOS versions.",
      "paths": ["~/Library/Developer/Xcode/watchOS DeviceSupport"],
      "exclusions": null,
      "category": "xcode_junk",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "xcode_archives_old",
      "name": "Old Xcode archives (>30d)",
      "description": "Build archives older than 30 days. Keep recent ones for symbolication.",
      "paths": ["~/Library/Developer/Xcode/Archives"],
      "exclusions": null,
      "category": "xcode_junk",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": 30,
      "mode": "eachChildAsItem"
    },
    {
      "id": "homebrew_cache",
      "name": "Homebrew downloads",
      "description": "Downloaded bottles and casks (re-downloaded on demand).",
      "paths": ["~/Library/Caches/Homebrew"],
      "exclusions": null,
      "category": "dev_tool_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "npm_cache",
      "name": "npm cache",
      "description": "npm package cache.",
      "paths": ["~/.npm/_cacache"],
      "exclusions": null,
      "category": "dev_tool_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "yarn_cache",
      "name": "Yarn cache",
      "description": "Yarn package cache.",
      "paths": ["~/Library/Caches/Yarn"],
      "exclusions": null,
      "category": "dev_tool_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "pnpm_store",
      "name": "pnpm store",
      "description": "pnpm content-addressable store.",
      "paths": ["~/Library/pnpm/store"],
      "exclusions": null,
      "category": "dev_tool_cache",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "gradle_caches",
      "name": "Gradle caches",
      "description": "Gradle dependency caches.",
      "paths": ["~/.gradle/caches"],
      "exclusions": null,
      "category": "dev_tool_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "android_build_cache",
      "name": "Android build cache",
      "description": "Gradle build cache used by Android Studio.",
      "paths": ["~/.android/build-cache"],
      "exclusions": null,
      "category": "dev_tool_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "maven_repo",
      "name": "Maven local repository",
      "description": "Locally downloaded Maven artifacts.",
      "paths": ["~/.m2/repository"],
      "exclusions": null,
      "category": "dev_tool_cache",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "cocoapods_cache",
      "name": "CocoaPods cache",
      "description": "Cached pod downloads.",
      "paths": ["~/Library/Caches/CocoaPods"],
      "exclusions": null,
      "category": "dev_tool_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "carthage_cache",
      "name": "Carthage cache",
      "description": "Carthage build cache.",
      "paths": ["~/Library/Caches/org.carthage.CarthageKit"],
      "exclusions": null,
      "category": "dev_tool_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "quicklook_thumbnails",
      "name": "Quick Look thumbnails",
      "description": "Cached preview thumbnails — regenerated on demand.",
      "paths": ["~/Library/Caches/com.apple.QuickLook.thumbnailcache"],
      "exclusions": null,
      "category": "user_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "wholePathAsItem"
    },
    {
      "id": "swift_pm_cache",
      "name": "Swift Package Manager caches",
      "description": "SPM package downloads and resolved metadata.",
      "paths": ["~/Library/Caches/org.swift.swiftpm"],
      "exclusions": null,
      "category": "dev_tool_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "library_application_support",
      "name": "App data — Application Support",
      "description": "Per-app local data (settings, indexes, plugins). Quarantined for 7 days when removed — review carefully.",
      "paths": ["~/Library/Application Support"],
      "exclusions": [
        "~/Library/Application Support/com.apple.TCC",
        "~/Library/Application Support/com.apple.spotlight",
        "~/Library/Application Support/com.apple.sharedfilelist",
        "~/Library/Application Support/MobileSync",
        "~/Library/Application Support/CallHistoryDB",
        "~/Library/Application Support/CallHistoryTransactions",
        "~/Library/Application Support/CrashReporter",
        "~/Library/Application Support/AddressBook",
        "~/Library/Application Support/iCloud",
        "~/Library/Application Support/MacCleaner"
      ],
      "category": "other",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "library_containers",
      "name": "Sandboxed app containers",
      "description": "Per-app sandbox containers. Removing one resets that app's settings + cache.",
      "paths": ["~/Library/Containers"],
      "exclusions": [
        "~/Library/Containers/com.apple.iCloud.fmfd",
        "~/Library/Containers/com.apple.Notes",
        "~/Library/Containers/com.apple.mail"
      ],
      "category": "other",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "library_group_containers",
      "name": "Group Containers",
      "description": "Shared sandbox storage between an app and its extensions. Re-created on next launch.",
      "paths": ["~/Library/Group Containers"],
      "exclusions": null,
      "category": "other",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "library_http_storages",
      "name": "HTTP storage caches",
      "description": "WKWebView HTTP cache per app — regenerated on demand.",
      "paths": ["~/Library/HTTPStorages"],
      "exclusions": null,
      "category": "user_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "library_webkit",
      "name": "WebKit data per app",
      "description": "WebKit storage created by apps embedding web views.",
      "paths": ["~/Library/WebKit"],
      "exclusions": null,
      "category": "user_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "library_cookies",
      "name": "App cookie store",
      "description": "Per-app cookie binplists. Apps re-create as needed.",
      "paths": ["~/Library/Cookies"],
      "exclusions": null,
      "category": "user_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "library_metadata_corespotlight",
      "name": "CoreSpotlight metadata",
      "description": "Per-app Spotlight index files — Spotlight re-indexes on demand.",
      "paths": ["~/Library/Metadata/CoreSpotlight"],
      "exclusions": null,
      "category": "user_cache",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "library_developer_coresimulator_devices",
      "name": "iOS Simulator devices",
      "description": "Each subfolder is a simulator device with its own apps + data. Older / unused devices can be huge.",
      "paths": ["~/Library/Developer/CoreSimulator/Devices"],
      "exclusions": null,
      "category": "xcode_junk",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "library_developer_xcode_user_data",
      "name": "Xcode user data — UserData",
      "description": "Per-project UserData (breakpoints, schemes, snapshots). Older entries are usually safe to drop.",
      "paths": ["~/Library/Developer/Xcode/UserData"],
      "exclusions": null,
      "category": "xcode_junk",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": 60,
      "mode": "eachChildAsItem"
    },
    {
      "id": "library_developer_xcode_user_states",
      "name": "Xcode user states",
      "description": "Old workspace state caches — repopulated on first build.",
      "paths": ["~/Library/Developer/Xcode/UserStates"],
      "exclusions": null,
      "category": "xcode_junk",
      "safetyLevel": "safe",
      "requiresAdmin": false,
      "minimumAgeDays": null,
      "mode": "eachChildAsItem"
    },
    {
      "id": "library_assistant",
      "name": "Siri assistant caches",
      "description": "Older Siri suggestions and assets.",
      "paths": ["~/Library/Assistant/SiriVocabulary"],
      "exclusions": null,
      "category": "user_cache",
      "safetyLevel": "review",
      "requiresAdmin": false,
      "minimumAgeDays": 30,
      "mode": "wholePathAsItem"
    }
  ]
}
